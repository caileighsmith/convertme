# Copy to .env on the droplet and fill in real values before deploying.
# `docker compose -f docker-compose.prod.yml up -d` reads this file automatically.

# Database (used by both the db container and the backend connection string)
POSTGRES_USER=convertme
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=convertme

# Backend
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace-with-output-of-openssl-rand-hex-32
JWT_EXPIRE_MINUTES=10080
FRONTEND_URL=https://convertme.co.uk
ENVIRONMENT=production

# Frontend
# Same host as FRONTEND_URL — nginx routes /api/* to the backend on the same domain.
NEXT_PUBLIC_API_URL=https://convertme.co.uk
